diff --git a/ios/Widgets/EntryView.swift b/ios/Widgets/EntryView.swift
--- a/ios/Widgets/EntryView.swift
+++ b/ios/Widgets/EntryView.swift
@@ -30,13 +30,42 @@
 
     if let node {
       if #available(iOS 17.0, *) {
         WidgetsDynamicView(name: entry.name, kind: .widget, node: node, entryIndex: entry.entryIndex, environmentString: widgetEnvironmentString)
-          .containerBackground(.clear, for: .widget)
+          .containerBackground(Self.extractContainerBackground(from: node), for: .widget)
       } else {
         WidgetsDynamicView(name: entry.name, kind: .widget, node: node, entryIndex: entry.entryIndex, environmentString: widgetEnvironmentString)
       }
     } else {
       EmptyView()
     }
   }
-}
+
+  /// iOS 17+ maps `.clear` to an opaque light background; use the widget's `background()` color (expo/expo#43654).
+  private static func extractContainerBackground(from node: [String: Any]) -> Color {
+    guard
+      let props = node["props"] as? [String: Any],
+      let modifiers = props["modifiers"] as? [[String: Any]],
+      let bgModifier = modifiers.first(where: { ($0["$type"] as? String) == "background" }),
+      let hex = bgModifier["color"] as? String,
+      let parsed = Self.parseHexColor(hex)
+    else {
+      return Color.black
+    }
+    return parsed
+  }
+
+  private static func parseHexColor(_ hex: String) -> Color? {
+    var s = hex.trimmingCharacters(in: .whitespacesAndNewlines)
+    if s.hasPrefix("#") {
+      s.removeFirst()
+    }
+    guard s.count == 6, let rgb = UInt64(s, radix: 16) else {
+      return nil
+    }
+    return Color(
+      red: Double((rgb >> 16) & 0xFF) / 255.0,
+      green: Double((rgb >> 8) & 0xFF) / 255.0,
+      blue: Double(rgb & 0xFF) / 255.0
+    )
+  }
+}
diff --git a/scripts/xcode-build-bundle.sh b/scripts/xcode-build-bundle.sh
--- a/scripts/xcode-build-bundle.sh
+++ b/scripts/xcode-build-bundle.sh
@@ -4,15 +4,9 @@
 
 EXPO_WIDGETS_PACKAGE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"
 
-# For classic main project build phases integration, will be no-op to prevent duplicated bundle creation.
-#
-# `$PROJECT_DIR` is passed by Xcode as the directory to the xcodeproj file.
-# in classic main project setup it is something like /path/to/app/ios
-# in new style pod project setup it is something like /path/to/app/ios/Pods
-PROJECT_DIR_BASENAME=$(basename $PROJECT_DIR)
-if [ "x$PROJECT_DIR_BASENAME" != "xPods" ]; then
-  exit 0
-fi
+# Build the JS bundle for every ExpoWidgets pod compile (Pods and non-Pods PROJECT_DIR).
+# Early-exiting when PROJECT_DIR basename !== "Pods" skipped bundle generation for `expo run:ios`,
+# which left widgets blank (see expo/expo#43646).
 
 # If PROJECT_ROOT is not specified, fallback to use Xcode PROJECT_DIR
 PROJECT_ROOT=${PROJECT_ROOT:-"$PROJECT_DIR/../.."}
