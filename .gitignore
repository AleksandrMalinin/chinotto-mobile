# Chinotto Mobile — ignored paths (see notes at bottom)

# Dependencies
node_modules/

# Only pnpm is used; ignore accidental npm/yarn lockfiles
package-lock.json
yarn.lock

# pnpm: local store if created inside the repo (e.g. sandboxed CI)
.pnpm-store/

# Expo / Metro
.expo/
dist/
web-build/
expo-env.d.ts

# Native: iOS project is tracked; Android still generated locally (`expo prebuild`) unless added later
/android

# Kotlin
.kotlin/

# Build / caches
*.tsbuildinfo
.turbo/
.cache/

# Merge / secrets (native signing)
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem

# Metro
.metro-health-check*

# Logs
*.log
npm-debug.*
yarn-debug.*
yarn-error.*
pnpm-debug.log*

# Test / coverage
coverage/

# Internal planning / handoff (local only)
INTERNAL_MOBILE_DESKTOP_STATE.md

# Environment (secrets; never commit — use `.env.example` as the template)
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging

# macOS
.DS_Store

# Editors (uncomment if you do not want machine-local settings in git)
# .vscode/
# .idea/

# ---
# What we commit: source, assets, app.json, pnpm-lock.yaml, docs, scripts, ios/.
# What stays local: node_modules, .expo, android/ prebuild output (if untracked), env files, logs, coverage,
# INTERNAL_*.
