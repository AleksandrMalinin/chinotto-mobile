# Copy to `.env` and fill in values from Firebase Console → Project settings → Your apps (Web).
# Never commit `.env` — it is gitignored.

# Required for sync (Firestore + Auth)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=

# Set to 1 to ship the iOS home screen widget (expo-widgets alpha) in release/EAS production prebuilds.
# Without it, NODE_ENV=production prebuild omits the widget extension; __DEV__ still enables JS + widget in debug.
# EXPO_PUBLIC_EXPERIMENTAL_IOS_HOME_WIDGET=1

# Optional but recommended (matches Firebase web app config)
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
