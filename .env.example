# Copy to `.env` and fill in values from Firebase Console → Project settings → Your apps (Web).
# Never commit `.env` — it is gitignored.

# --- Optional: developer / QA (iOS dev client) ---
# App Store screenshots: enable in `src/features/screenshotMode.ts`, then e.g. EXPO_PUBLIC_SCREENSHOT_MODE=1
# Less noisy RevenueCat logs: EXPO_PUBLIC_REVENUECAT_QUIET=1

# Optional: Umami — use the **mobile** website in the dashboard (its own Website ID + domain, e.g. chinotto.mobile).
# Opt-in only: first launch shows a one-time sheet (if unset, no prompt); Settings → Privacy keeps the toggle.
# EXPO_PUBLIC_UMAMI_URL=https://cloud.umami.is
# EXPO_PUBLIC_UMAMI_WEBSITE_ID=
# Must match Umami → that website → Domain (defaults to chinotto.mobile in code if unset).
# EXPO_PUBLIC_UMAMI_HOSTNAME=chinotto.mobile

# Required for sync (Firestore + Auth)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=

# App update policy: app always tries Firebase Remote Config (native); failures fall back to
# built-in mock (enabled: false). Requires GoogleService-Info.plist / google-services.json (app.json).
# RC key: chinotto_app_update_json — import starter: docs/app-update/firebase-remote-config-template.json

# Sync paywall (RevenueCat plans) before “Continue with Apple”. Use true, 1, or yes (case-insensitive).
# Read via (1) Metro-inlined process.env and (2) app.config.js → extra.enableSyncPaywall (dotenv) after native rebuild.
# After changing: `npx expo start -c` and `npx expo run:ios` (or EAS with the same var in project env).
# EXPO_PUBLIC_ENABLE_PAYWALL=true

# RevenueCat public iOS SDK key (RevenueCat dashboard → App → API keys). Safe in the client; still keep out of git via `.env`.
# For EAS production builds, set the same variable in EAS environment secrets.
# EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
# EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
# Optional iOS: force StoreKit 1 if product.introPrice stays empty in dev (StoreKit file / missing In-App Purchase key). Values: STOREKIT_1 | STOREKIT_2
# EXPO_PUBLIC_REVENUECAT_IOS_STOREKIT_VERSION=STOREKIT_1

# Set to 1 to ship the iOS home screen widget (expo-widgets alpha) in release/EAS production prebuilds.
# Without it, NODE_ENV=production prebuild omits the widget extension; __DEV__ still enables JS + widget in debug.
# EXPO_PUBLIC_EXPERIMENTAL_IOS_HOME_WIDGET=1

# Optional but recommended (matches Firebase web app config)
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
