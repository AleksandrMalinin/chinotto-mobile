{
  "expo": {
    "name": "Chinotto",
    "owner": "bogart91",
    "slug": "chinotto-mobile",
    "version": "1.0.0",
    "scheme": "chinotto",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chinotto.mobile",
      "usesAppleSignIn": true,
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.chinotto.mobile"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0e",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.chinotto.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "75f836d7-4d98-401b-a733-0ac61429d31e"
      }
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-sqlite",
      [
        "expo-widgets",
        {
          "groupIdentifier": "group.com.chinotto.mobile",
          "bundleIdentifier": "com.chinotto.mobile.ExpoWidgetsTarget",
          "widgets": [
            {
              "name": "CaptureHomeWidget",
              "displayName": "Chinotto",
              "description": "Open capture to jot a thought.",
              "supportedFamilies": [
                "systemSmall"
              ]
            }
          ]
        }
      ],
      [
        "expo-sharing",
        {
          "ios": {
            "enabled": true,
            "appGroups": ["group.com.chinotto.mobile"],
            "activationRule": {
              "supportsText": true,
              "supportsWebUrlWithMaxCount": 5,
              "supportsWebPageWithMaxCount": 5
            }
          },
          "android": {
            "enabled": true,
            "singleShareMimeTypes": [
              "text/plain",
              "text/*"
            ],
            "multipleShareMimeTypes": [
              "text/plain",
              "text/*"
            ]
          }
        }
      ],
      [
        "./plugins/withIosSplashLogoFixedConstraints.js",
        {
          "imageWidth": 120
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "backgroundColor": "#0a0a0e",
          "resizeMode": "contain",
          "imageWidth": 120
        }
      ]
    ]
  }
}
